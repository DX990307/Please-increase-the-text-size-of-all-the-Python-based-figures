{
  "canvas": {
    "figure_width": 6.8,
    "figure_height": 3.2,
    "dpi": 180,
    "figure_facecolor": "#F8FBFF",
    "axes_facecolor": "#FFFFFF"
  },
  "text": {
    "font_family": "DejaVu Sans",
    "font_size": 20,
    "title_size": 40,
    "axis_label_size": 18,
    "tick_label_size": 14,
    "legend_font_size": 14,
    "title_text": "Larger Text For Paper Figures",
    "x_label_text": "Normalized Time",
    "y_label_text": "Score",
    "title_color": "#102A43",
    "label_color": "#243B53",
    "tick_color": "#334E68"
  },
  "axes": {
    "grid_color": "#BCCCDC",
    "grid_alpha": 0.28,
    "spine_color": "#829AB1",
    "x_min": 0.0,
    "x_max": 6.2,
    "y_min": 0.2,
    "y_max": 1.0
  },
  "lines": {
    "line_width": 2.6,
    "marker_size": 7,
    "line_alpha": 0.95
  },
  "legend": {
    "columns": 2,
    "location": "upper center"
  },
  "series": {
    "primary": {
      "label": "Readable baseline",
      "color": "#0B6E4F",
      "marker": "o"
    },
    "secondary": {
      "label": "Comparison curve",
      "color": "#C84C09",
      "marker": "s"
    }
  }
}
