{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Font Bigger Prototype",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extension=teamsmelly.smellgptextension",
        "--disable-extension=figma.figma-vscode-extension",
        "${workspaceFolder}/examples/minimal-paper"
      ]
    }
  ]
}
